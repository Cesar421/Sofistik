!#!Chapter Modell
+PROG AQUA urs:1

HEAD 'Torsionsbalken km 7,7+64'

HEAD 'Materialien'

STO#LN 0                                                $ [-] Sprache ; 0 = Deutsch
STO#UO 0                                                $ [-] Einheiten

PAGE LANO  UNIO
     #LN   #UO

ECHO MAT

NORM DIN EN1993-2005 CAT D

$ Stahlbau:

STEE NO  TYPE  CLAS  SCM  TITL
     31     S  235   1.0  'S 235'                       $ [-] Teilsicherheitsbeiwert Ɣ_M0 = 1,0

END

+PROG AQUA urs:2

HEAD 'Querschnitte'

ECHO SECT

$ Torsionsbalken:

LET#Qn   11                             $ [-] Querschnittsnummer
LET#Mn   31                             $ [-] Materialnummer
LET#h    500.0                          $ [mm] Höhe
LET#b    300.0                          $ [mm] Breite
LET#t    12.5                           $ [mm] Dicke

PROF NO   TYPE  Z1   Z2  Z3  MNO  DTYP
     #Qn  SH    #h   #b  #t  #Mn  S

$ Gründungspfahl:

LET#Qn   21                             $ [-] Querschnittsnummer
LET#Mn   31                             $ [-] Materialnummer
STO#D_Sr 610.0E-3                       $ [m] Durchmesser Stahlrohrs
LET#t_Sr 6.3E-3                         $ [m] Dicke Stahlrohrs
LET#t_kr (3.25E-3)/2                    $ [m] Dickenverlust infolge Korrosion ; DIN EN 1993-5:2010-12, 4.4 (2)
LET#t    #t_Sr-#t_kr                    $ [m] effektive Dicke

TUBE NO   D         T      MNO  TITL
     #Qn  #D_Sr[m]  #t[m]  #Mn  'Gründungspfahl'

$ Pfosten:

LET#Qn   31                             $ [-] Querschnittsnummer
LET#Mn   31                             $ [-] Materialnummer

PROF NO   TYPE  Z1   MNO  DTYP
     #Qn  HEB   160  #Mn  S

END

+PROG SOFIMSHC urs:3

HEAD 'Torsionsbalken km 7,7+64'

HEAD 'FEM'

LET#GDIV 10000                  $ [-] Gruppendivisor

SYST 3D #GDIV NEGZ

CTRL MESH 2

CTRL HMIN 0.20

#DEFINE Gp

LET#Qn 21                       $ [-] Querschnittsnummer

LET#NO #Ach*1000

SPT #NO+100  Z  0.00  Y #Y  X 0.0  ;  SPTP REF #NO+000  TYPE KF  GRP 5
SPT #NO+110  Z -1.00  Y #Y  X 0.0
SPT #NO+120  Z -4.00  Y #Y  X 0.0
SPT #NO+130  Z -4.25  Y #Y  X 0.0
SPT #NO+140  Z -6.65  Y #Y  X 0.0
SPT #NO+150  Z -7.00  Y #Y  X 0.0  FIX PZ

SLN #NO+100  #NO+100  #NO+110  SNO #Qn  GRP 2

SLN #NO+110  #NO+110  #NO+120  SNO #Qn  GRP 2  ;  SLNS DRX +1  CA #K_st1  BFIX #D_Sr  FCTA 0.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRY +1  CA #K_st1  BFIX #D_Sr  FCTA 0.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRX +1  CA #K_dy1  BFIX #D_Sr  FCTA 0.0  FCTE 1.0  GRP 12  REFT >FIX
                                                  SLNS DRY +1  CA #K_dy1  BFIX #D_Sr  FCTA 0.0  FCTE 1.0  GRP 12  REFT >FIX

SLN #NO+120  #NO+120  #NO+130  SNO #Qn  GRP 2  ;  SLNS DRX +1  CA #K_st1  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRY +1  CA #K_st1  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRX +1  CA #K_dy1  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 12  REFT >FIX
                                                  SLNS DRY +1  CA #K_dy1  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 12  REFT >FIX

SLN #NO+130  #NO+130  #NO+140  SNO #Qn  GRP 2  ;  SLNS DRX +1  CA #K_st2  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRY +1  CA #K_st2  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRX +1  CA #K_dy2  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 12  REFT >FIX
                                                  SLNS DRY +1  CA #K_dy2  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 12  REFT >FIX

SLN #NO+140  #NO+140  #NO+150  SNO #Qn  GRP 2  ;  SLNS DRX +1  CA #K_st3  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRY +1  CA #K_st3  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 11  REFT >FIX
                                                  SLNS DRX +1  CA #K_dy3  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 12  REFT >FIX
                                                  SLNS DRY +1  CA #K_dy3  BFIX #D_Sr  FCTA 1.0  FCTE 1.0  GRP 12  REFT >FIX

#ENDDEF

#DEFINE Pf

LET#Qn 31                       $ [-] Querschnittsnummer

LET#NO #Ach*1000

SPT #NO+000  Z 0.25  Y #Y  X 0.0
SPT #NO+200  Z 0.50  Y #Y  X 0.0  ;  SPTP REF #NO+000  TYPE KF  GRP 5
SPT #NO+210  Z 2.50  Y #Y  X 0.0
SPT #NO+220  Z 4.50  Y #Y  X 0.0

SLN #NO+200  #NO+200  #NO+210  SNO #Qn  GRP 3

SLN #NO+210  #NO+210  #NO+220  SNO #Qn  GRP 3

#ENDDEF

#DEFINE Tb

LET#Qn 11                       $ [-] Querschnittsnummer

LET#NO1 #Ach1*1000
LET#NO2 #Ach2*1000

SLN #NO1+000  #NO1+000  #NO2+000  SNO #Qn  GRP 1

#ENDDEF

!*!Label Gründungspfahl und Pfosten

LET#E_st1  6.0E3                $ [kN/m²] statisches Steifemodul Erdschicht 1
LET#E_st2 10.0E3                $ [kN/m²] statisches Steifemodul Erdschicht 2
LET#E_st3 15.0E3                $ [kN/m²] statisches Steifemodul Erdschicht 3

LET#E_dy1  60.0E3               $ [kN/m²] dynamisches Steifemodul Erdschicht 1
LET#E_dy2  80.0E3               $ [kN/m²] dynamisches Steifemodul Erdschicht 2
LET#E_dy3 100.0E3               $ [kN/m²] dynamisches Steifemodul Erdschicht 3

LET#K_st1 #E_st1/#D_Sr          $ [kN/m³] statisches Bettungsmodul Erdschicht 1
LET#K_st2 #E_st2/#D_Sr          $ [kN/m³] statisches Bettungsmodul Erdschicht 2
LET#K_st3 #E_st3/#D_Sr          $ [kN/m³] statisches Bettungsmodul Erdschicht 3

LET#K_dy1 #E_dy1/#D_Sr          $ [kN/m³] dynamisches Bettungsmodul Erdschicht 1
LET#K_dy2 #E_dy2/#D_Sr          $ [kN/m³] dynamisches Bettungsmodul Erdschicht 2
LET#K_dy3 #E_dy3/#D_Sr          $ [kN/m³] dynamisches Bettungsmodul Erdschicht 3

LET#Ach 1                       $ [-] Achse
LET#Y   0.0                     $ [m]

#INCLUDE Pf
#INCLUDE Gp

LET#Ach 2                       $ [-] Achse
LET#Y   2.5                     $ [m]

#INCLUDE Pf

LET#Ach 3                       $ [-] Achse
LET#Y   5.0                     $ [m]

#INCLUDE Pf

LET#Ach 4                       $ [-] Achse
LET#Y   7.5                     $ [m]

#INCLUDE Pf

LET#Ach 5                       $ [-] Achse
LET#Y   10.0                    $ [m]

#INCLUDE Pf

LET#Ach 6                       $ [-] Achse
LET#Y   12.5                    $ [m]

#INCLUDE Pf
#INCLUDE Gp

!*!Label Torsionsbalken

LET#Ach1 1                      $ [-] Achse 1
LET#Ach2 #Ach1+1                $ [-] Achse 2

LET#Lp 5                        $ [-] Anzahl an Torsionsbalken (zwischen Pfosten)

LOOP #Lp

        #INCLUDE Tb

        LET#Ach1 #Ach1+1         $ [-] Achse 1
        LET#Ach2 #Ach1+1         $ [-] Achse 2

ENDLOOP

END

!#!Chapter Eigenfrequenzen
+PROG ASE urs:4

HEAD 'Analyse'

STO#w_W  0.25                   $ [kN/m²] Wichte Wand
LET#b_W  2.50                   $ [m] Breite Wand
STO#h_W  4.00                   $ [m] Höhe Wand

LET#m_W (#w_W/9.81)*#b_W*#h_W   $ [t] Masse Wand

LET#Lp 6                        $ [-] Anzahl an Pfosten

LET#Ach 1                       $ [-] Achse

LOOP #Lp

        LET#NO #Ach*1000

        MASS NO       MX
             #NO+210  #m_W

        LET#Ach #Ach+1          $ [-] Achse

ENDLOOP

STO#m_Wlks (#w_W/9.81)*#h_W*1.25        $ [t] Masse Wand Links
STO#m_Wrch (#w_W/9.81)*#h_W*1.25        $ [t] Masse Wand Rechts

STO#m_Slks (25.0/9.81)*0.16*1.50*1.25   $ [t] Masse Sockel Links
STO#m_Srch (25.0/9.81)*0.16*1.50*1.25   $ [t] Masse Sockel Rechts

LET#Ach 1                               $ [-] Achse

        LET#NO #Ach*1000

        MASS NO       MX
             #NO+210  #m_Wlks-(#m_W/2)
             #NO+000  #m_Slks

LET#Ach 6                               $ [-] Achse

        LET#NO #Ach*1000

        MASS NO       MX
             #NO+210  #m_Wrch-(#m_W/2)
             #NO+000  #m_Srch

LET#dE 3                        $ [-] dynamische Eigenwerte

GRP 1,2,3,5,12                  $ [-] Gruppen (dynamische Steifemodule)

EIGE NEIG  LC  ETYP=LANC
     #dE   1

END

!#!Chapter ständige Einwirkungen
+PROG SOFILOAD urs:5

HEAD 'Einwirkungen'

ECHO ACT

ACT TYPE GAMU GAMF PSI0 PSI1 PSI2 SUP  TITL
    G_1  1.35 1.00 1.00 1.00 1.00 PERM 'Eingengewicht'
    G_2  1.35 1.00 1.00 1.00 1.00 PERM 'Ständige Lasten'
    ZUG  1.30 0.00 0.80 0.70 0.50 EXCL 'Druck-Sog'
    W    1.50 0.00 0.60 0.20 0.00 EXCL 'Wind'

ACT TYPE GAMU GAMF PSI0 PSI1 PSI2 SUP  TITL
    GZT  1.00 0.00 1.00 1.00 1.00 EXEX 'GZT'
    ERM  1.00 0.00 1.00 1.00 1.00 EXEX 'Ermüdung'

END

+PROG SOFILOAD urs:6

HEAD 'ständige Lasten (G_k,2)'

LET#G2_Wand #w_W*#h_W                   $ [kN/m] Gewicht Wand

LET#G2_Wlks #m_Wlks*9.81        $ [kN] Gewicht Wand Links
LET#G2_Wrch #m_Wrch*9.81        $ [kN] Gewicht Wand Rechts

LET#G2_Slks #m_Slks*9.81        $ [kN] Gewicht Sockel Links
LET#G2_Srch #m_Srch*9.81        $ [kN] Gewicht Sockel Rechts

LC 200 G_2 TITL 'G_k,2'
BEAM TO    PA        FROM=GRP
     1     #G2_Wand

LET#Ach 1                       $ [-] Achse

        LET#NO #Ach*1000

        NODE NO       P1
             #NO+210  #G2_Wlks
             #NO+000  #G2_Slks

LET#Ach 6                       $ [-] Achse

        LET#NO #Ach*1000

        NODE NO       P1
             #NO+210  #G2_Wrch
             #NO+000  #G2_Srch

END

+PROG CSM urs:7

HEAD 'Bauzustände'

CS NO   TYPE  TITL
   100  G_1   'G_k,1'
   200  G_2   'G_k,2'

GRP NO  ICS1=100
    1                                   $ [-] Torsionsbalken
    2                                   $ [-] Gründungspfähle
    3                                   $ [-] Pfosten
    5                                   $ [-] kinetische Kopplungen

GRP NO  PHIF  ICS1=100
    11  1.0                             $ [-] Bettung (statische Steifemodule)

LC NO   TYPE  ICS1
   200  G_2   200

END

+apply $(NAME)_csm.dat

+PROG TEMPLATE urs:8
END

!#!Chapter veränderliche Einwirkungen
+PROG SOFILOAD urs:9

HEAD 'Druck-Sog (Q_k,1)'

!*!Label Blocks

#DEFINE qD_vor

AREA Z1      Z2      Z3      Z4       P1       P2       P3       P4      Y1=#Y1 Y2=#Y2 Y3=#Y2 Y4=#Y1 X1=0.0 X2=0.0 X3=0.0 X4=0.0 NO=#Ach1 REF=LAR TYPE=PXX
     #zh_10  #zh_10  #zh_09  #zh_09  +#qD_10  +#qD_10  +#qD_09  +#qD_09
     #zh_09  #zh_09  #zh_08  #zh_08  +#qD_09  +#qD_09  +#qD_08  +#qD_08
     #zh_08  #zh_08  #zh_07  #zh_07  +#qD_08  +#qD_08  +#qD_07  +#qD_07
     #zh_07  #zh_07  #zh_06  #zh_06  +#qD_07  +#qD_07  +#qD_06  +#qD_06
     #zh_06  #zh_06  #zh_05  #zh_05  +#qD_06  +#qD_06  +#qD_05  +#qD_05
     #zh_05  #zh_05  #zh_04  #zh_04  +#qD_05  +#qD_05  +#qD_04  +#qD_04
     #zh_04  #zh_04  #zh_03  #zh_03  +#qD_04  +#qD_04  +#qD_03  +#qD_03
     #zh_03  #zh_03  #zh_02  #zh_02  +#qD_03  +#qD_03  +#qD_02  +#qD_02
     #zh_02  #zh_02  #zh_01  #zh_01  +#qD_02  +#qD_02  +#qD_01  +#qD_01
     #zh_01  #zh_01  #zh_00  #zh_00  +#qD_01  +#qD_01  +#qD_00  +#qD_00

#ENDDEF

#DEFINE qD_hin

AREA Z1      Z2      Z3      Z4       P1       P2       P3       P4      Y1=#Y1 Y2=#Y2 Y3=#Y2 Y4=#Y1 X1=0.0 X2=0.0 X3=0.0 X4=0.0 NO=#Ach1 REF=LAR TYPE=PXX
     #zh_10  #zh_10  #zh_09  #zh_09  -#qD_10  -#qD_10  -#qD_09  -#qD_09
     #zh_09  #zh_09  #zh_08  #zh_08  -#qD_09  -#qD_09  -#qD_08  -#qD_08
     #zh_08  #zh_08  #zh_07  #zh_07  -#qD_08  -#qD_08  -#qD_07  -#qD_07
     #zh_07  #zh_07  #zh_06  #zh_06  -#qD_07  -#qD_07  -#qD_06  -#qD_06
     #zh_06  #zh_06  #zh_05  #zh_05  -#qD_06  -#qD_06  -#qD_05  -#qD_05
     #zh_05  #zh_05  #zh_04  #zh_04  -#qD_05  -#qD_05  -#qD_04  -#qD_04
     #zh_04  #zh_04  #zh_03  #zh_03  -#qD_04  -#qD_04  -#qD_03  -#qD_03
     #zh_03  #zh_03  #zh_02  #zh_02  -#qD_03  -#qD_03  -#qD_02  -#qD_02
     #zh_02  #zh_02  #zh_01  #zh_01  -#qD_02  -#qD_02  -#qD_01  -#qD_01
     #zh_01  #zh_01  #zh_00  #zh_00  -#qD_01  -#qD_01  -#qD_00  -#qD_00

#ENDDEF

#DEFINE qD_Pf_vor

LINE Z1      Z2       P1            P2          Y1=#Y Y2=#Y X1=0.0 X2=0.0 TYPE=PXX REF=SLN
     #zh_10  #zh_09  +(#qD_10*#b)  +(#qD_09*#b)
     #zh_09  #zh_08  +(#qD_09*#b)  +(#qD_08*#b)
     #zh_08  #zh_07  +(#qD_08*#b)  +(#qD_07*#b)
     #zh_07  #zh_06  +(#qD_07*#b)  +(#qD_06*#b)
     #zh_06  #zh_05  +(#qD_06*#b)  +(#qD_05*#b)
     #zh_05  #zh_04  +(#qD_05*#b)  +(#qD_04*#b)
     #zh_04  #zh_03  +(#qD_04*#b)  +(#qD_03*#b)
     #zh_03  #zh_02  +(#qD_03*#b)  +(#qD_02*#b)
     #zh_02  #zh_01  +(#qD_02*#b)  +(#qD_01*#b)
     #zh_01  #zh_00  +(#qD_01*#b)  +(#qD_00*#b)

#ENDDEF

#DEFINE qD_Pf_hin

LINE Z1      Z2       P1            P2          Y1=#Y Y2=#Y X1=0.0 X2=0.0 TYPE=PXX REF=SLN
     #zh_10  #zh_09  -(#qD_10*#b)  -(#qD_09*#b)
     #zh_09  #zh_08  -(#qD_09*#b)  -(#qD_08*#b)
     #zh_08  #zh_07  -(#qD_08*#b)  -(#qD_07*#b)
     #zh_07  #zh_06  -(#qD_07*#b)  -(#qD_06*#b)
     #zh_06  #zh_05  -(#qD_06*#b)  -(#qD_05*#b)
     #zh_05  #zh_04  -(#qD_05*#b)  -(#qD_04*#b)
     #zh_04  #zh_03  -(#qD_04*#b)  -(#qD_03*#b)
     #zh_03  #zh_02  -(#qD_03*#b)  -(#qD_02*#b)
     #zh_02  #zh_01  -(#qD_02*#b)  -(#qD_01*#b)
     #zh_01  #zh_00  -(#qD_01*#b)  -(#qD_00*#b)

#ENDDEF

!*!Label LARs

LET#Ach1 1                      $ [-] Achse 1
LET#Ach2 #Ach1+1                $ [-] Achse 2

LET#Lp 5                        $ [-] Anzahl an Torsionsbalken (zwischen Pfosten)

LOOP #Lp

        LET#NO1 #Ach1*1000
        LET#NO2 #Ach2*1000

        LAR NO     Y1        Y2        Y3        Y4        X1=GPT X2=GPT X3=GPT X4=GPT
            #Ach1  #NO1+200  #NO1+220  #NO2+220  #NO2+200

        LET#Ach1 #Ach1+1        $ [-] Achse 1
        LET#Ach2 #Ach1+1        $ [-] Achse 2

ENDLOOP

!*!Label Parameter

LET#z_OW 4.5                    $ [m] Z OK Wand
LET#z_SO 1.0                    $ [m] Z SO

LET#q_DS 0.216                  $ [kN/m²] q_DS ohne phi_H!!!

LET#ph_10 0.60                  $ [-] phi_H (z/h = 1,0 ; h = 3,0)
LET#ph_09 0.68                  $ [-] phi_H (z/h = 0,9 ; h = 3,0)
LET#ph_08 0.74                  $ [-] phi_H (z/h = 0,8 ; h = 3,0)
LET#ph_07 0.80                  $ [-] phi_H (z/h = 0,7 ; h = 3,0)
LET#ph_06 0.86                  $ [-] phi_H (z/h = 0,6 ; h = 3,0)
LET#ph_05 0.90                  $ [-] phi_H (z/h = 0,5 ; h = 3,0)
LET#ph_04 0.94                  $ [-] phi_H (z/h = 0,4 ; h = 3,0)
LET#ph_03 0.96                  $ [-] phi_H (z/h = 0,3 ; h = 3,0)
LET#ph_02 0.98                  $ [-] phi_H (z/h = 0,2 ; h = 3,0)
LET#ph_01 1.00                  $ [-] phi_H (z/h = 0,1 ; h = 3,0)
LET#ph_00 1.00                  $ [-] phi_H (z/h = 0,0 ; h = 3,0)

LET#Dz #z_OW-#z_SO              $ [m] Delta Z

LET#zh_10 (1.0*#Dz)+#z_SO
LET#zh_09 (0.9*#Dz)+#z_SO
LET#zh_08 (0.8*#Dz)+#z_SO
LET#zh_07 (0.7*#Dz)+#z_SO
LET#zh_06 (0.6*#Dz)+#z_SO
LET#zh_05 (0.5*#Dz)+#z_SO
LET#zh_04 (0.4*#Dz)+#z_SO
LET#zh_03 (0.3*#Dz)+#z_SO
LET#zh_02 (0.2*#Dz)+#z_SO
LET#zh_01 (0.1*#Dz)+#z_SO
LET#zh_00 (0.0*#Dz)+#z_SO

LET#qD_10 #q_DS*#ph_10
LET#qD_09 #q_DS*#ph_09
LET#qD_08 #q_DS*#ph_08
LET#qD_07 #q_DS*#ph_07
LET#qD_06 #q_DS*#ph_06
LET#qD_05 #q_DS*#ph_05
LET#qD_04 #q_DS*#ph_04
LET#qD_03 #q_DS*#ph_03
LET#qD_02 #q_DS*#ph_02
LET#qD_01 #q_DS*#ph_01
LET#qD_00 #q_DS*#ph_00

!*!Label Lastfälle

LC 301 ZUG TITL 'Q_k,1'

LET#Y   0.0                     $ [m] Y Achse
LET#b   1.25                    $ [m] Breite der daneben liegenden Fläche

#INCLUDE qD_Pf_vor

LET#Ach1  1                     $ [-] Achse 1
LET#Y1  0.0                     $ [m] Y Achse 1
LET#Y2  2.5                     $ [m] Y Achse 2

#INCLUDE qD_vor

LC 302 ZUG TITL 'Q_k,1'

LET#Y   0.0                     $ [m] Y Achse
LET#b   1.25                    $ [m] Breite der daneben liegenden Fläche

#INCLUDE qD_Pf_hin

LET#Ach1  1                     $ [-] Achse 1
LET#Y1  0.0                     $ [m] Y Achse 1
LET#Y2  2.5                     $ [m] Y Achse 2

#INCLUDE qD_vor

LET#Ach1  2                     $ [-] Achse 1
LET#Y1  2.5                     $ [m] Y Achse 1
LET#Y2  5.0                     $ [m] Y Achse 2

#INCLUDE qD_vor

LC 303 ZUG TITL 'Q_k,1'

LET#Y   0.0                     $ [m] Y Achse
LET#b   1.25                    $ [m] Breite der daneben liegenden Fläche

#INCLUDE qD_Pf_hin

LET#Ach1  1                     $ [-] Achse 1
LET#Y1  0.0                     $ [m] Y Achse 1
LET#Y2  2.5                     $ [m] Y Achse 2

#INCLUDE qD_hin

LET#Ach1  2                     $ [-] Achse 1
LET#Y1  2.5                     $ [m] Y Achse 1
LET#Y2  5.0                     $ [m] Y Achse 2

#INCLUDE qD_vor

LET#Ach1  3                     $ [-] Achse 1
LET#Y1  5.0                     $ [m] Y Achse 1
LET#Y2  7.5                     $ [m] Y Achse 2

#INCLUDE qD_vor

LC 304 ZUG TITL 'Q_k,1'

LET#Ach1  1                     $ [-] Achse 1
LET#Y1  0.0                     $ [m] Y Achse 1
LET#Y2  2.5                     $ [m] Y Achse 2

#INCLUDE qD_hin

LET#Ach1  2                     $ [-] Achse 1
LET#Y1  2.5                     $ [m] Y Achse 1
LET#Y2  5.0                     $ [m] Y Achse 2

