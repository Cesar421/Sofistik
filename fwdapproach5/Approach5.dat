+PROG SOFILOAD urs:10

HEAD 'Wind (W_k)'

LET#q_D 0.50                    $ [kN/m²] Geschwindigkeitsdruck (Windzone 1)

LEt#c_pn 1.2                    $ [-] Druckbeiwert (c_p,net - Bereich D) ; DIN EN 1991-1-4:2010-12, 7.4.1 (1), Tabelle 7.9

LET#Wk #q_D*#c_pn               $ [kN/m²]

LET#b1 1.25                     $ [m] Breite 1 der daneben liegenden Fläche
LET#b2 1.25                     $ [m] Breite 2 der daneben liegenden Fläche

LET#Ach1 1                      $ [-] Achse 1
LET#Ach2 6                      $ [-] Achse 2

LET#NO1 #Ach1*1000
LET#NO2 #Ach2*1000

LC 401 W TITL 'W_k'
AREA NO  P1=+#Wk REF=LAR TYPE=PXX
     1
     2
     3
     4
     5
LINE Y1        Y2         P1          P2         X1=GPT X2=GPT TYPE=PXX REF=SLN
     #NO1+200  #NO1+220  +(#Wk*#b1)  +(#Wk*#b1)
     #NO2+200  #NO2+220  +(#Wk*#b2)  +(#Wk*#b2)

LC 402 W TITL 'W_k'
AREA NO  P1=-#Wk REF=LAR TYPE=PXX
     1
     2
     3
     4
     5
LINE Y1        Y2         P1          P2         X1=GPT X2=GPT TYPE=PXX REF=SLN
     #NO1+200  #NO1+220  -(#Wk*#b1)  -(#Wk*#b1)
     #NO2+200  #NO2+220  -(#Wk*#b2)  -(#Wk*#b2)

END

