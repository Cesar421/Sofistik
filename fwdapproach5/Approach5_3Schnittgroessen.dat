+PROG WING

HEAD 'Parameter: Gruppen, MaÔe'

#DEFINE WG_GRP

GRP 1,2,3,5                                             $ [-] Gruppen

#ENDDEF

STO#U1_Nx  35.0                                         $ [kN]  max. Normalkraft Nx
STO#U2_Nx  45.0                                         $ [kN]  min. Normalkraft Nx
STO#U1_Vz  45.0                                         $ [kN]  max. Querkraft Vz
STO#U2_Vz  45.0                                         $ [kN]  min. Querkraft Vz
STO#U1_Vy  20.0                                         $ [kN]  max. Querkraft Vy
STO#U2_Vy  20.0                                         $ [kN]  min. Querkraft Vy
STO#U1_My 130.0                                         $ [kNm] max. Moment My
STO#U2_My 130.0                                         $ [kNm] min. Moment My
STO#U1_Mz  75.0                                         $ [kNm] max. Moment Mz
STO#U2_Mz  75.0                                         $ [kNm] min. Moment Mz
STO#U1_Mt  45.0                                         $ [kNm] max. Moment Mt
STO#U2_Mt  45.0                                         $ [kNm] min. Moment Mt

END

+PROG WING

HEAD 'Torsionsbalken: Normalkraft Nx'

STO#FR #FR+0.5                                          $ [-]  Seitenummer

#INCLUDE FORMAT

CTRL OPT EMPT VAL EXTR

VIEW TYPE DIRE X -1 Y 0 Z 0 AXIS NEGZ ROTA 0            $ [-] Ansicht
SCHH H6 #H6

#INCLUDE WG_GRP

$ Fenster Nr.1:

MOVE X     Y     Z    UNIT=PR A=0 SCHH=#SH SET=PEND DTYP=TEXT PICT=0
     10.0  90.0  0.0
TEXT 'max. Normalkraft Nx'

LC   NO #LS1+1
AND  POSI 1 POSL 0 POSR 100 POSD 50 POSU 100            $ [-] Lage des Fensters

BEAM TYPE N UNIT #U1_Nx SCHH YES

$LC   NO #LS2+1
$AND  POSI 1 POSL 0 POSR 100 POSD 50 POSU 100            $ [-] Lage des Fensters

$BEAM TYPE N UNIT LAST SCHH YES

$ Fenster Nr.2:

MOVE X     Y     Z    UNIT=PR A=0 SCHH=#SH SET=PEND DTYP=TEXT PICT=0
     10.0  90.0  0.0
TEXT 'min. Normalkraft Nx'

LC   NO #LS1+11
AND  POSI 2 POSL 0 POSR 100 POSD 0 POSU 50              $ [-] Lage des Fensters

BEAM TYPE N UNIT #U2_Nx SCHH YES

$LC   NO #LS2+11
$AND  POSI 2 POSL 0 POSR 100 POSD 0 POSU 50              $ [-] Lage des Fensters

$BEAM TYPE N UNIT LAST SCHH YES

END

