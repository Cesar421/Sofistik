     #LCC+5   MZ    'MZ max'
     #LCC+6   MT    'MT max'

COMB LCST     SCOM  TITL      EXTR=#XT2 LC1=#TYP
     #LCC+11  N     'N  min'
     #LCC+12  VZ    'VZ min'
     #LCC+13  VY    'VY min'
     #LCC+14  MY    'MY min'
     #LCC+15  MZ    'MZ min'
     #LCC+16  MT    'MT min'

