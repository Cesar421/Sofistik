    <task>
     <name>Kombination (GZT)</name>
     <function state="4" id="33" internal_id="24">tedview::sof_tedview_dll</function>
     <file>+PROG SOFILOAD urs:6
HEAD 'Aktionstypen GZT + ERM'

ACT TYPE GAMU GAMF PSI0 PSI1 PSI2 SUP  TITL
    GZT  1.00 0.00 1.00 1.00 1.00 EXEX 'GZT'
    ERM  1.00 0.00 1.00 1.00 1.00 EXEX 'Ermüdung'

END

+PROG MAXIMA urs:1
HEAD 'GZT Kombinationen'

STO#LCS 200

COMB #LCS/10 'DESI' TYPE 'GZT'

ACT G_1
    LC 1
ACT G_2
    LC 2
ACT TYPE
    ZUG
    W

SUPP LC      TYPE  TITL      EXTR=MAX COMB=#LCS/10 ETYP=BEAM
     #LCS+1  N     'N  max'
     #LCS+2  VZ    'VZ max'
     #LCS+3  VY    'VY max'
     #LCS+4  MY    'MY max'
     #LCS+5  MZ    'MZ max'
     #LCS+6  MT    'MT max'

SUPP LC      TYPE  TITL      EXTR=MIN COMB=#LCS/10 ETYP=BEAM
     #LCS+11  N     'N  min'
     #LCS+12  VZ    'VZ min'
     #LCS+13  VY    'VY min'
     #LCS+14  MY    'MY min'
     #LCS+15  MZ    'MZ min'
     #LCS+16  MT    'MT min'

END

+PROG AQB urs:34.1
HEAD 'Nachweise GZT'

STO#LCC 8000
STO#XT1 'MAXD'
STO#XT2 'MIND'
STO#TYP 'GZT'

BEAM TO CS0=0 FROM=GRP
     1

#DEFINE LC_CB

LC NO    TYPE  GAMU  GAMF  SUP   TITL     CST=CS0
   1     G_1   1.35  1.00  PERM  'G_k,1'
   2     G_2   1.35  1.00  PERM  'G_k,2'
   -     #TYP  1.00  0.00  EXEX  '∑ Q_k'

COMB LCST     SCOM  TITL      EXTR=#XT1 LC1=G LC2=#TYP
     #LCC+1   N     'N  max'
     #LCC+2   VZ    'VZ max'
     #LCC+3   VY    'VY max'
     #LCC+4   MY    'MY max'
     #LCC+5   MZ    'MZ max'
     #LCC+6   MT    'MT max'

COMB LCST     SCOM  TITL      EXTR=#XT2 LC1=G LC2=#TYP
     #LCC+11  N     'N  min'
     #LCC+12  VZ    'VZ min'
     #LCC+13  VY    'VY min'
     #LCC+14  MY    'MY min'
     #LCC+15  MZ    'MZ min'
     #LCC+16  MT    'MT min'

COMB GMAX LCST #LCC+18

#ENDDEF

#INCLUDE LC_CB

STRE E F

END</file>
    </task>
